# Copy to Scripts/.env and fill in. Do NOT commit Scripts/.env (gitignored).
# Used by Scripts/backfill-spots-city-country.mjs.

# Supabase project URL — from project settings → API → Project URL.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase service_role key (NOT the anon key). RLS is bypassed by this key,
# which the backfill needs because it writes spots rows that belong to many
# different users. Treat it like a database root password — never commit.
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps Platform API key with "Places API (New)" enabled.
# Same key family used by the iOS app's PlacesAPIService.
GOOGLE_PLACES_API_KEY=

# Optional: cap the rows processed per run (default 500).
# BACKFILL_LIMIT=500

# Optional: pause between Google calls in ms (default 60). Increase if you
# start seeing OVER_QUERY_LIMIT or rate-limit errors.
# BACKFILL_RATE_MS=60
